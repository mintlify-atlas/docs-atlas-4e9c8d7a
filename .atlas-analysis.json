  "keyFeatures": [
    "Import bookmarks from Chromium-based browsers (Chrome, Edge, Brave, etc.)",
    "Semantic search powered by AI embeddings (embeddinggemma-300m)",
    "Organize bookmarks with folders and hierarchical structure",
    "Browser extension for quick bookmark saving and import",
    "Full-text search and filtering capabilities",
    "Automatic metadata fetching (favicons, og:image, descriptions)",
    "Drag-and-drop import interface",
    "Keyboard-friendly navigation",
    "Dark mode support",
    "Privacy-focused with user data ownership"
  ],
  "publicApiSurface": [
    "createBookmark(title, url, folderId?, favicon?, ogImage?, description?)",
    "batchCreateBookmarks(bookmarks[])",
    "getBookmarks()",
    "updateBookmark(bookmarkId, ...fields)",
    "deleteBookmark(bookmarkId)",
    "createFolder(name, parentId?)",
    "getFolders()",
    "updateFolder(folderId, name?, parentId?)",
    "deleteFolder(folderId)",
    "upsertBookmarkEmbedding(bookmarkId, embedding, ...metadata)",
    "deleteBookmarkEmbedding(bookmarkId)",
    "getEmbeddingIndexStats()",
    "repairEmbeddingIndexStats()",
    "getUserStats()",
    "deleteAllData()",
    "/api/import - POST endpoint for batch importing bookmarks and folders",
    "/api/metadata - GET endpoint for fetching URL metadata",
    "parseBookmarkHtml(html) - Parse Netscape Bookmark HTML format"
  ]
}
